generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// UŻYTKOWNICY (ADMIN)
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      UserRole @default(ADMIN)
  createdAt DateTime @default(now())
}

enum UserRole {
  ADMIN
  SUPERADMIN
}

// ============================================
// PLACÓWKI
// ============================================

model Facility {
  id         Int      @id @default(autoincrement())
  name       String
  address    String   // ulica z numerem
  postalCode String   @default("")
  city       String
  phone      String
  hours      String
  lat        Float
  lng        Float
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

// ============================================
// ZAMÓWIENIA
// ============================================

model Order {
  id          String      @id @default(cuid())

  // Dane klienta
  firstName   String
  lastName    String
  email       String
  phone       String
  address     String
  pesel       String   @default("")
  noPesel     Boolean  @default(false)
  needInvoice Boolean  @default(false)
  companyName String   @default("")
  nip         String   @default("")

  // Panel badawczy
  panelType   PanelType
  panelTier   PanelTier
  material    String
  elements    String

  // Placówka
  facilityId  Int?
  facility    Facility?   @relation(fields: [facilityId], references: [id])
  isOnline    Boolean     @default(false)

  // Płatność
  price       Int         // w groszach (23000 = 230 zł)
  status      OrderStatus @default(PENDING)

  // Kod rabatowy
  promoCodeId String?
  promoCode   PromoCode?  @relation(fields: [promoCodeId], references: [id])
  discount    Int         @default(0)

  // PayU
  payuOrderId String?     @unique

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  paidAt      DateTime?

  payments    Payment[]
}

enum PanelType {
  PROFILAKTYKA
  ONKOLOGICZNY
}

enum PanelTier {
  PODSTAWOWY
  ROZSZERZONY
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  COMPLETED
  CANCELLED
  REFUNDED
}

// ============================================
// PŁATNOŚCI (historia PayU)
// ============================================

model Payment {
  id          String        @id @default(cuid())
  orderId     String
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  payuOrderId String?
  status      PaymentStatus @default(NEW)
  amount      Int           @default(0)
  method      String?

  createdAt   DateTime      @default(now())
}

enum PaymentStatus {
  NEW
  PENDING
  WAITING_FOR_CONFIRMATION
  COMPLETED
  CANCELED
}

// ============================================
// KODY RABATOWE
// ============================================

model PromoCode {
  id          String       @id @default(cuid())
  code        String       @unique

  type        DiscountType
  value       Int          // PERCENT: 10 = 10%, FIXED: 1000 = 10 zł

  maxUses     Int?
  usedCount   Int          @default(0)

  validFrom   DateTime     @default(now())
  validUntil  DateTime?
  active      Boolean      @default(true)

  source      String?      // np. "influencer_jan", "facebook_maj"

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  orders      Order[]
}

enum DiscountType {
  PERCENT
  FIXED
}

// ============================================
// USTAWIENIA SERWISU
// ============================================

model SiteSettings {
  id        String @id @default("main")

  // Dane firmy
  siteName  String?
  email     String?
  phone     String?
  address   String?

  // Google Analytics 4
  ga4Id     String?

  // Google Search Console
  gscVerification String?

  // Google Tag Manager
  gtmId     String?

  // Google reCAPTCHA v3
  recaptchaEnabled   Boolean @default(false)
  recaptchaSiteKey   String?
  recaptchaSecretKey String?

  // PayU
  payuEnabled      Boolean @default(false)
  payuSandbox      Boolean @default(true)
  payuPosId        String?
  payuClientSecret String?
  payuMd5Key       String?

  // Powiadomienia e-mail
  emailNotificationsEnabled Boolean @default(false)
  notificationEmail         String?

  // Szablony e-mail
  emailSubjectConfirmation String?  // Temat emaila potwierdzenia
  emailIntroText           String?  // Tekst powitalny w emailu (np. "Dziękujemy za zamówienie!")
  emailFacilityText        String?  // Tekst instrukcji dla placówki
  emailOnlineText          String?  // Tekst dla zamówień online
  emailFooterText          String?  // Stopka emaila

  // SMTP
  smtpHost     String?
  smtpPort     Int?     @default(587)
  smtpUser     String?
  smtpPassword String?
  smtpFrom     String?  // np. "Onkopierwiastki <noreply@onkopierwiastki.pl>"
  smtpSecure   Boolean  @default(false)

  updatedAt DateTime @updatedAt
}
